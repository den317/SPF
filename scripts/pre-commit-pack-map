#!/usr/bin/env bash
# pack-lint (WP-242) — должен идти до exit 0 auto-MAP
bash "/Users/tserentserenov/IWE/DS-MCP/knowledge-mcp/scripts/pack-lint.sh"
#
# Pre-commit hook: auto-regenerate MAP when Pack entities change.
#
# Checks if any .md files under pack/ are staged, runs generate-map.py,
# and stages the updated MAP file if it changed.
#
# Install: symlink this file into each Pack repo's .git/hooks/pre-commit
#   ln -sf ../../../SPF/scripts/pre-commit-pack-map .git/hooks/pre-commit
#
# Requires: python3, pyyaml

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"

# Delta-aware ID-collision guard (WP-388 Ф14, DP.SC.181): блокирует коммит,
# если staged-added entity-файл вносит уже занятый ID. Dual-path resolution
# как у generate-map (на macOS readlink -f не работает → SCRIPT_DIR может быть
# .git/hooks; тогда берём sibling SPF). Не найден → skip (CI-детектор бэкстоп).
DELTA_GUARD=""
if [[ -f "$SCRIPT_DIR/check-id-collision-delta.sh" ]]; then
    DELTA_GUARD="$SCRIPT_DIR/check-id-collision-delta.sh"
elif [[ -f "$REPO_ROOT/../SPF/scripts/check-id-collision-delta.sh" ]]; then
    DELTA_GUARD="$REPO_ROOT/../SPF/scripts/check-id-collision-delta.sh"
fi
if [[ -n "$DELTA_GUARD" ]]; then
    bash "$DELTA_GUARD" || exit 1
fi

# Resolve generate-map.py location
# Priority: 1) same dir as this script, 2) SPF/scripts/ sibling repo
if [[ -f "$SCRIPT_DIR/generate-map.py" ]]; then
    GENERATE_MAP="$SCRIPT_DIR/generate-map.py"
elif [[ -f "$REPO_ROOT/../SPF/scripts/generate-map.py" ]]; then
    GENERATE_MAP="$REPO_ROOT/../SPF/scripts/generate-map.py"
else
    echo "[auto-MAP] generate-map.py not found, skipping."
    exit 0
fi

# Find pack directory (pack/*/00-pack-manifest.md), skip _template
PACK_DIR=""
for manifest in "$REPO_ROOT"/pack/*/00-pack-manifest.md; do
    if [[ -f "$manifest" ]]; then
        dir="$(dirname "$manifest")"
        dirname_base="$(basename "$dir")"
        # Skip template directories
        [[ "$dirname_base" == _* ]] && continue
        PACK_DIR="$dir"
        break
    fi
done

if [[ -z "$PACK_DIR" ]]; then
    # Not a Pack repo or no manifest — skip silently
    exit 0
fi

# Check if any pack .md files are staged
STAGED_PACK_FILES="$(git diff --cached --name-only --diff-filter=ACMR -- 'pack/*.md' 'pack/**/*.md' 2>/dev/null || true)"

if [[ -z "$STAGED_PACK_FILES" ]]; then
    # No pack files staged — nothing to do
    exit 0
fi

echo "[auto-MAP] Pack files changed, regenerating MAP..."

# Run generate-map.py
if ! python3 "$GENERATE_MAP" "$PACK_DIR" --manifest 2>&1 | while read -r line; do
    echo "[auto-MAP] $line"
done; then
    echo "[auto-MAP] Warning: MAP generation failed, committing without update."
    exit 0
fi

# Stage updated MAP and manifest if changed
for pattern in "$PACK_DIR/07-map/*.MAP.*.md" "$PACK_DIR/00-pack-manifest.md"; do
    for changed_file in $pattern; do
        [[ -f "$changed_file" ]] || continue
        rel_path="${changed_file#$REPO_ROOT/}"
        if ! git diff --quiet -- "$rel_path" 2>/dev/null; then
            git add "$rel_path"
            echo "[auto-MAP] Staged updated: $rel_path"
        fi
    done
done

echo "[auto-MAP] Done."
exit 0
